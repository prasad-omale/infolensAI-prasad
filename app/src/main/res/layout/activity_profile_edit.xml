<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingBottom="32dp"
    tools:context=".ProfileEditBottomSheet">

    <!-- Profile Avatar Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/avatarSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profileAvatar"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:backgroundTint="#4DB6AC"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleAppearance"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp" />

        <TextView
            android:id="@+id/tvAvatarInitials"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RO"
            android:textColor="@color/white"
            android:textSize="48sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/profileAvatar"
            app:layout_constraintEnd_toEndOf="@id/profileAvatar"
            app:layout_constraintStart_toStartOf="@id/profileAvatar"
            app:layout_constraintTop_toTopOf="@id/profileAvatar" />

        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/camera_icon_bg"
            android:padding="8dp"
            android:src="@drawable/ic_camera"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileAvatar"
            app:layout_constraintVertical_bias="1.0"
            app:layout_constraintHorizontal_bias="0.5"
            android:layout_marginTop="-20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Form Fields -->
    <LinearLayout
        android:id="@+id/formFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="64dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/avatarSection">

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/profile_input_bg"
            android:hint="Name"
            android:paddingHorizontal="24dp"
            android:textColor="@color/white"
            android:textColorHint="#666666"
            android:textSize="18sp"
            android:inputType="textPersonName" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvProfileHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="64dp"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="Your profile helps people recognize you"
        android:textColor="#888888"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/formFields" />

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvProfileHint"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:background="@drawable/save_button_bg"
            android:text="Save profile"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:text="Cancel"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>