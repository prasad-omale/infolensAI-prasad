<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".MainActivity">

    <!-- Layered Rings and Circles -->

    <View
        android:id="@+id/ring_outer_stroke"
        android:layout_width="380dp"
        android:layout_height="380dp"
        android:alpha="0.05"
        android:background="@drawable/ring_shape"
        app:layout_constraintBottom_toTopOf="@+id/cardView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Middle stroke ring -->
    <View
        android:id="@+id/ring_mid_stroke"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:alpha="0.08"
        android:background="@drawable/ring_shape"
        app:layout_constraintBottom_toBottomOf="@id/ring_outer_stroke"
        app:layout_constraintEnd_toEndOf="@id/ring_outer_stroke"
        app:layout_constraintStart_toStartOf="@id/ring_outer_stroke"
        app:layout_constraintTop_toTopOf="@id/ring_outer_stroke" />

    <!-- Inner black circle background for logo -->
    <View
        android:id="@+id/circle_inner_solid"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="1.0"
        android:background="@drawable/black_circle"
        app:layout_constraintBottom_toBottomOf="@id/ring_outer_stroke"
        app:layout_constraintEnd_toEndOf="@id/ring_outer_stroke"
        app:layout_constraintStart_toStartOf="@id/ring_outer_stroke"
        app:layout_constraintTop_toTopOf="@id/ring_outer_stroke" />

    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/icon_logo"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name"
        app:layout_constraintBottom_toBottomOf="@id/circle_inner_solid"
        app:layout_constraintEnd_toEndOf="@id/circle_inner_solid"
        app:layout_constraintStart_toStartOf="@id/circle_inner_solid"
        app:layout_constraintTop_toTopOf="@id/circle_inner_solid" />

    <!-- Bottom Card Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/card_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.4">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            android:layout_marginTop="40dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/onboarding_title"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="normal"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="60dp"
            android:layout_marginTop="24dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/onboarding_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/titleText" />

        <!-- Get Started Button -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnGetStarted"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/button_background"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivArrowHandle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/white_circle"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_forward"
                android:contentDescription="@string/get_started"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvBtnText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/get_started"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>